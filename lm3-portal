<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LM3 Enterprise | Client Portal</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --purple: #4B0082;
    --purple-mid: #6A0DAD;
    --purple-light: #9B59B6;
    --purple-pale: #F3EAF9;
    --gold: #C9A227;
    --gold-light: #F0D060;
    --gold-pale: #FDF8E7;
    --white: #FFFFFF;
    --gray-100: #F7F7F8;
    --gray-200: #EBEBEF;
    --gray-400: #9A94A5;
    --gray-700: #3D3548;
    --shadow-sm: 0 2px 8px rgba(75,0,130,0.08);
    --shadow-md: 0 6px 24px rgba(75,0,130,0.12);
    --shadow-lg: 0 16px 48px rgba(75,0,130,0.18);
    --radius: 14px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--gray-100);
    color: var(--gray-700);
    min-height: 100vh;
  }

/* ─── LOGIN ─── */
#loginScreen {
display: flex;
align-items: center;
justify-content: center;
min-height: 100vh;
background: linear-gradient(135deg, var(–purple) 0%, var(–purple-mid) 60%, #1a0030 100%);
padding: 20px;
}
.login-card {
background: var(–white);
border-radius: 20px;
padding: 48px 40px;
width: 100%;
max-width: 420px;
box-shadow: var(–shadow-lg);
text-align: center;
animation: slideUp 0.5s ease;
}
@keyframes slideUp {
from { opacity: 0; transform: translateY(24px); }
to   { opacity: 1; transform: translateY(0); }
}
.logo-badge {
width: 72px; height: 72px;
background: linear-gradient(135deg, var(–purple) 0%, var(–purple-mid) 100%);
border-radius: 18px;
display: flex; align-items: center; justify-content: center;
margin: 0 auto 24px;
box-shadow: 0 8px 20px rgba(75,0,130,0.35);
}
.logo-badge span {
font-family: ‘Playfair Display’, serif;
color: var(–gold-light);
font-size: 22px;
font-weight: 700;
letter-spacing: 1px;
}
.login-card h1 {
font-family: ‘Playfair Display’, serif;
font-size: 26px;
color: var(–purple);
margin-bottom: 6px;
}
.login-card p { color: var(–gray-400); font-size: 14px; margin-bottom: 32px; }
.field { text-align: left; margin-bottom: 16px; }
.field label { display: block; font-size: 12px; font-weight: 600; color: var(–gray-700); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 8px; }
.field input {
width: 100%;
padding: 13px 16px;
border: 1.5px solid var(–gray-200);
border-radius: 10px;
font-family: ‘DM Sans’, sans-serif;
font-size: 15px;
color: var(–gray-700);
outline: none;
transition: border-color 0.2s;
}
.field input:focus { border-color: var(–purple-light); }
.btn-primary {
width: 100%;
padding: 14px;
background: linear-gradient(135deg, var(–purple) 0%, var(–purple-mid) 100%);
color: var(–white);
border: none;
border-radius: 10px;
font-family: ‘DM Sans’, sans-serif;
font-size: 15px;
font-weight: 600;
cursor: pointer;
transition: opacity 0.2s, transform 0.1s;
margin-top: 8px;
}
.btn-primary:hover { opacity: 0.92; transform: translateY(-1px); }
.btn-primary:active { transform: translateY(0); }
.login-hint { font-size: 12px; color: var(–gray-400); margin-top: 20px; }
.login-hint strong { color: var(–purple); }

/* ─── APP SHELL ─── */
#app { display: none; flex-direction: column; min-height: 100vh; }

/* Header */
.app-header {
background: linear-gradient(135deg, var(–purple) 0%, var(–purple-mid) 100%);
color: var(–white);
padding: 0 24px;
display: flex;
align-items: center;
justify-content: space-between;
height: 64px;
box-shadow: 0 2px 12px rgba(75,0,130,0.3);
position: sticky; top: 0; z-index: 100;
}
.header-brand {
font-family: ‘Playfair Display’, serif;
font-size: 20px;
color: var(–gold-light);
letter-spacing: 0.5px;
}
.header-user {
display: flex; align-items: center; gap: 10px;
}
.avatar {
width: 36px; height: 36px;
background: rgba(255,255,255,0.2);
border-radius: 50%;
display: flex; align-items: center; justify-content: center;
font-weight: 700; font-size: 13px;
}
.header-user span { font-size: 13px; font-weight: 500; opacity: 0.9; }
#logoutBtn {
background: rgba(255,255,255,0.15);
border: 1px solid rgba(255,255,255,0.25);
color: white;
border-radius: 8px;
padding: 5px 12px;
font-size: 12px;
font-family: ‘DM Sans’, sans-serif;
cursor: pointer;
transition: background 0.2s;
}
#logoutBtn:hover { background: rgba(255,255,255,0.25); }

/* Nav Tabs */
.nav-tabs {
background: var(–white);
display: flex;
border-bottom: 2px solid var(–gray-200);
overflow-x: auto;
}
.nav-tab {
flex: 1;
padding: 14px 20px;
background: none;
border: none;
font-family: ‘DM Sans’, sans-serif;
font-size: 14px;
font-weight: 500;
color: var(–gray-400);
cursor: pointer;
border-bottom: 3px solid transparent;
margin-bottom: -2px;
white-space: nowrap;
transition: color 0.2s, border-color 0.2s;
}
.nav-tab.active { color: var(–purple); border-bottom-color: var(–gold); font-weight: 600; }
.nav-tab:hover:not(.active) { color: var(–purple-light); }

/* Main content */
.main { padding: 24px; max-width: 720px; margin: 0 auto; flex: 1; }
.tab-panel { display: none; animation: fadeIn 0.3s ease; }
.tab-panel.active { display: block; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

/* ─── DASHBOARD ─── */
.welcome-banner {
background: linear-gradient(135deg, var(–purple) 0%, var(–purple-mid) 100%);
border-radius: var(–radius);
padding: 24px;
color: white;
margin-bottom: 20px;
position: relative;
overflow: hidden;
}
.welcome-banner::after {
content: ‘’;
position: absolute;
top: -40px; right: -40px;
width: 140px; height: 140px;
border-radius: 50%;
background: rgba(201,162,39,0.15);
}
.welcome-banner h2 { font-family: ‘Playfair Display’, serif; font-size: 22px; margin-bottom: 4px; }
.welcome-banner p { opacity: 0.8; font-size: 13px; }

.section-title {
font-size: 11px;
font-weight: 700;
text-transform: uppercase;
letter-spacing: 1.2px;
color: var(–gray-400);
margin-bottom: 12px;
margin-top: 24px;
}

/* Service card */
.service-card {
background: var(–white);
border-radius: var(–radius);
padding: 20px;
box-shadow: var(–shadow-sm);
margin-bottom: 14px;
border-left: 4px solid var(–purple-light);
}
.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
.service-name { font-weight: 700; font-size: 16px; color: var(–purple); }
.service-status {
background: #E8F8F0; color: #2ECC71;
font-size: 11px; font-weight: 700;
padding: 4px 10px; border-radius: 20px;
letter-spacing: 0.5px;
}
.service-status.warning { background: #FEF9E7; color: #D4AC0D; }
.service-detail { font-size: 13px; color: var(–gray-400); margin-bottom: 4px; }
.service-detail strong { color: var(–gray-700); }

/* Payment due alert */
.payment-alert {
background: var(–gold-pale);
border: 1.5px solid var(–gold);
border-radius: var(–radius);
padding: 16px 20px;
display: flex;
align-items: center;
gap: 14px;
margin-bottom: 14px;
}
.alert-icon { font-size: 28px; }
.alert-body { flex: 1; }
.alert-body h4 { font-weight: 700; color: var(–gray-700); margin-bottom: 2px; font-size: 14px; }
.alert-body p { font-size: 12px; color: var(–gray-400); }
.btn-pay {
background: linear-gradient(135deg, var(–gold) 0%, #A07818 100%);
color: white;
border: none;
border-radius: 8px;
padding: 10px 18px;
font-family: ‘DM Sans’, sans-serif;
font-size: 13px;
font-weight: 700;
cursor: pointer;
white-space: nowrap;
transition: opacity 0.2s, transform 0.1s;
}
.btn-pay:hover { opacity: 0.9; transform: translateY(-1px); }

/* ─── PAYMENTS ─── */
.pay-card {
background: var(–white);
border-radius: var(–radius);
padding: 28px;
box-shadow: var(–shadow-sm);
text-align: center;
margin-bottom: 16px;
}
.pay-card h3 { font-family: ‘Playfair Display’, serif; font-size: 20px; color: var(–purple); margin-bottom: 8px; }
.amount-display {
font-size: 48px;
font-weight: 700;
color: var(–purple);
margin: 16px 0;
font-family: ‘Playfair Display’, serif;
}
.amount-display span { font-size: 22px; color: var(–gray-400); }
.pay-card p { color: var(–gray-400); font-size: 13px; margin-bottom: 24px; }
.zelle-btn {
display: inline-flex;
align-items: center;
gap: 10px;
background: #6D1ED4;
color: white;
border: none;
border-radius: 12px;
padding: 14px 32px;
font-family: ‘DM Sans’, sans-serif;
font-size: 15px;
font-weight: 700;
cursor: pointer;
text-decoration: none;
transition: opacity 0.2s, transform 0.1s;
width: 100%;
justify-content: center;
}
.zelle-btn:hover { opacity: 0.9; transform: translateY(-1px); }
.zelle-icon { font-size: 20px; }
.divider { display: flex; align-items: center; gap: 12px; color: var(–gray-400); font-size: 12px; margin: 16px 0; }
.divider::before, .divider::after { content: ‘’; flex: 1; height: 1px; background: var(–gray-200); }
.cashapp-btn {
display: inline-flex;
align-items: center;
gap: 10px;
background: #00C244;
color: white;
border: none;
border-radius: 12px;
padding: 14px 32px;
font-family: ‘DM Sans’, sans-serif;
font-size: 15px;
font-weight: 700;
cursor: pointer;
text-decoration: none;
transition: opacity 0.2s, transform 0.1s;
width: 100%;
justify-content: center;
}
.cashapp-btn:hover { opacity: 0.9; transform: translateY(-1px); }

.history-row {
background: var(–white);
border-radius: 10px;
padding: 14px 18px;
display: flex;
justify-content: space-between;
align-items: center;
margin-bottom: 8px;
box-shadow: var(–shadow-sm);
}
.history-row .date { font-size: 13px; color: var(–gray-400); }
.history-row .desc { font-size: 14px; font-weight: 500; }
.history-row .amt { font-weight: 700; color: var(–purple); }
.badge-paid { background: #E8F8F0; color: #27AE60; font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 20px; }

/* ─── SUPPORT TICKETS ─── */
.ticket-form {
background: var(–white);
border-radius: var(–radius);
padding: 24px;
box-shadow: var(–shadow-sm);
margin-bottom: 20px;
}
.ticket-form h3 { font-family: ‘Playfair Display’, serif; font-size: 18px; color: var(–purple); margin-bottom: 6px; }
.ticket-form p { font-size: 13px; color: var(–gray-400); margin-bottom: 20px; }
.form-row { margin-bottom: 16px; }
.form-row label { display: block; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; color: var(–gray-700); margin-bottom: 8px; }
.form-row select, .form-row textarea, .form-row input[type=text] {
width: 100%;
padding: 12px 16px;
border: 1.5px solid var(–gray-200);
border-radius: 10px;
font-family: ‘DM Sans’, sans-serif;
font-size: 14px;
color: var(–gray-700);
outline: none;
transition: border-color 0.2s;
background: var(–white);
}
.form-row select:focus, .form-row textarea:focus, .form-row input[type=text]:focus { border-color: var(–purple-light); }
.form-row textarea { resize: vertical; min-height: 100px; }
.btn-submit {
background: linear-gradient(135deg, var(–purple) 0%, var(–purple-mid) 100%);
color: white;
border: none;
border-radius: 10px;
padding: 13px 28px;
font-family: ‘DM Sans’, sans-serif;
font-size: 14px;
font-weight: 600;
cursor: pointer;
transition: opacity 0.2s, transform 0.1s;
width: 100%;
}
.btn-submit:hover { opacity: 0.9; transform: translateY(-1px); }

.ticket-item {
background: var(–white);
border-radius: var(–radius);
padding: 18px 20px;
box-shadow: var(–shadow-sm);
margin-bottom: 10px;
border-left: 4px solid var(–gray-200);
}
.ticket-item.open { border-left-color: var(–gold); }
.ticket-item.in-progress { border-left-color: var(–purple-light); }
.ticket-item.resolved { border-left-color: #2ECC71; }
.ticket-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
.ticket-title { font-weight: 700; font-size: 14px; color: var(–gray-700); }
.ticket-meta { font-size: 12px; color: var(–gray-400); margin-bottom: 8px; }
.ticket-desc { font-size: 13px; color: var(–gray-700); }
.status-badge {
font-size: 10px; font-weight: 700; padding: 3px 10px; border-radius: 20px;
letter-spacing: 0.5px;
}
.status-badge.open { background: #FEF9E7; color: #D4AC0D; }
.status-badge.in-progress { background: #F3EAF9; color: var(–purple); }
.status-badge.resolved { background: #E8F8F0; color: #27AE60; }

/* ─── ADMIN ─── */
#adminGate { text-align: center; padding: 40px 20px; }
#adminGate h3 { font-family: ‘Playfair Display’, serif; font-size: 20px; color: var(–purple); margin-bottom: 8px; }
#adminGate p { color: var(–gray-400); font-size: 13px; margin-bottom: 20px; }
.admin-input {
padding: 12px 16px;
border: 1.5px solid var(–gray-200);
border-radius: 10px;
font-family: ‘DM Sans’, sans-serif;
font-size: 14px;
width: 200px;
text-align: center;
outline: none;
margin-right: 8px;
transition: border-color 0.2s;
}
.admin-input:focus { border-color: var(–purple-light); }
.btn-sm {
padding: 12px 20px;
background: var(–purple);
color: white;
border: none;
border-radius: 10px;
font-family: ‘DM Sans’, sans-serif;
font-size: 14px;
font-weight: 600;
cursor: pointer;
}
#adminDash { display: none; }
.admin-stat {
background: var(–white);
border-radius: var(–radius);
padding: 20px;
box-shadow: var(–shadow-sm);
text-align: center;
flex: 1;
}
.stat-grid { display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
.admin-stat h4 { font-size: 13px; color: var(–gray-400); margin-bottom: 8px; font-weight: 500; }
.admin-stat .stat-num { font-family: ‘Playfair Display’, serif; font-size: 36px; color: var(–purple); font-weight: 700; }
.admin-ticket {
background: var(–white);
border-radius: var(–radius);
padding: 16px 20px;
box-shadow: var(–shadow-sm);
margin-bottom: 10px;
display: flex;
justify-content: space-between;
align-items: center;
gap: 12px;
}
.admin-ticket .client-name { font-weight: 700; font-size: 14px; color: var(–purple); }
.admin-ticket .ticket-issue { font-size: 13px; color: var(–gray-400); margin-top: 2px; }
.admin-ticket .time { font-size: 11px; color: var(–gray-400); }
.update-status {
padding: 7px 12px;
border: 1.5px solid var(–gray-200);
border-radius: 8px;
font-family: ‘DM Sans’, sans-serif;
font-size: 12px;
cursor: pointer;
color: var(–gray-700);
background: white;
}

/* Success toast */
#toast {
position: fixed;
bottom: 24px;
left: 50%;
transform: translateX(-50%) translateY(80px);
background: var(–purple);
color: white;
padding: 14px 24px;
border-radius: 50px;
font-size: 14px;
font-weight: 500;
box-shadow: var(–shadow-lg);
transition: transform 0.4s cubic-bezier(.34,1.56,.64,1);
z-index: 9999;
white-space: nowrap;
}
#toast.show { transform: translateX(-50%) translateY(0); }

/* Payment modal */
#payModal {
display: none;
position: fixed;
inset: 0;
background: rgba(0,0,0,0.5);
z-index: 500;
align-items: center;
justify-content: center;
padding: 20px;
}
#payModal.show { display: flex; }
.modal-card {
background: white;
border-radius: 20px;
padding: 32px;
max-width: 380px;
width: 100%;
text-align: center;
box-shadow: var(–shadow-lg);
animation: slideUp 0.3s ease;
}
.modal-card h3 { font-family: ‘Playfair Display’, serif; font-size: 22px; color: var(–purple); margin-bottom: 8px; }
.modal-card p { color: var(–gray-400); font-size: 13px; margin-bottom: 24px; }
.modal-close {
position: absolute;
top: 16px; right: 16px;
background: none; border: none;
font-size: 20px; cursor: pointer;
color: var(–gray-400);
}
.modal-card { position: relative; }
</style>

</head>
