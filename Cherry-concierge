<script>
  // ── VIEW ROUTER ──
  function switchView(viewId) {
    document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
    document.getElementById(viewId).classList.add('active');
    window.scrollTo(0, 0);

    const tabMap = {
      'view-home': 'tab-home',
      'view-quote': 'tab-quote',
      'view-book': 'tab-book',
      'view-portal': 'tab-portal',
      'view-dashboard': 'tab-dashboard'
    };
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    const tab = document.getElementById(tabMap[viewId]);
    if (tab) tab.classList.add('active');
  }

  // ── QUOTE CALCULATOR ──
  const pricing = {
    board: { base: 8, min: 60 },
    grazing: { base: 14, min: 200 },
    bar: { base: 18, min: 350 },
    corporate: { base: 12, min: 150 }
  };
  const addons = { theme: 40, delivery: 35, veg: 0, setup: 75 };

  function calcQuote() {
    const service = document.getElementById('q-service').value;
    const guests = parseInt(document.getElementById('q-guests').value);
    const p = pricing[service];
    let total = Math.max(guests * p.base, p.min);

    if (document.getElementById('chip-theme').classList.contains('selected')) total += addons.theme;
    if (document.getElementById('chip-delivery').classList.contains('selected')) total += addons.delivery;
    if (document.getElementById('chip-setup').classList.contains('selected')) total += addons.setup;

    const deposit = Math.round(total * 0.5);
    document.getElementById('quote-total').textContent = '$' + total.toLocaleString();
    document.getElementById('quote-deposit').textContent = `Deposit due: $${deposit} · Balance at event`;
  }

  function toggleChip(id) {
    document.getElementById(id).classList.toggle('selected');
  }

  // ── BOOKING STEPS ──
  let currentStep = 1;
  function goStep(n) {
    document.getElementById('step-' + currentStep).classList.remove('active');
    currentStep = n;
    document.getElementById('step-' + n).classList.add('active');
    updateStepDots(n);
    window.scrollTo(0, 0);
  }
  function showSuccess() {
    document.getElementById('step-' + currentStep).classList.remove('active');
    document.getElementById('step-success').classList.add('active');
    document.querySelectorAll('.step-dot').forEach(d => d.classList.remove('active'));
    document.querySelectorAll('.step-dot').forEach(d => d.classList.add('done'));
  }
  function updateStepDots(n) {
    for (let i = 1; i <= 3; i++) {
      const dot = document.getElementById('sdot-' + i);
      dot.classList.remove('active', 'done');
      if (i < n) dot.classList.add('done');
      else if (i === n) dot.classList.add('active');
    }
  }

  // ── PREP TOGGLE ──
  function togglePrep(el) {
    el.classList.toggle('checked');
    const text = el.nextElementSibling;
    text.classList.toggle('done');
  }

  // Init quote
  calcQuote();
</script>

